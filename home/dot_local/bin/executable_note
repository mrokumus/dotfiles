#!/usr/bin/env bash

set -euo pipefail

VAULT="${NOTES_VAULT:-$HOME/notes}"
EDITOR_CMD="${EDITOR:-nvim}"

slugify() {
  echo "$*" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-|-$//g'
}

month_name() {
  date +"%B"
}

week_of_month() {
  local day
  day=$(date +"%-d")
  echo $(( (day - 1) / 7 + 1 ))
}

render_template() {
  local template="$1"
  local title="${2:-}"
  local scope="${3:-}"
  local area="${4:-}"

  sed \
    -e "s|{{date}}|$(date +%F)|g" \
    -e "s|{{year}}|$(date +%Y)|g" \
    -e "s|{{month}}|$(month_name)|g" \
    -e "s|{{week}}|$(week_of_month)|g" \
    -e "s|{{title}}|$title|g" \
    -e "s|{{scope}}|$scope|g" \
    -e "s|{{area}}|$area|g" \
    "$template"
}

ensure_file() {
  local file="$1"
  local template="$2"
  local title="${3:-}"
  local scope="${4:-}"
  local area="${5:-}"

  mkdir -p "$(dirname "$file")"

  if [ ! -f "$file" ]; then
    render_template "$template" "$title" "$scope" "$area" > "$file"
  fi
}

open_file() {
  local file="$1"
  "$EDITOR_CMD" "$file"
}

jotform_week_path() {
  echo "$VAULT/weekly/jotform/$(date +%Y)/$(month_name)/$(week_of_month).md"
}

personal_week_path() {
  echo "$VAULT/weekly/personal/$(date +%Y)/$(month_name)/$(week_of_month).md"
}

personal_day_path() {
  echo "$VAULT/daily/personal/$(date +%F).md"
}

case "${1:-}" in
  jw|jotform-week)
    file="$(jotform_week_path)"
    ensure_file "$file" "$VAULT/templates/jotform-weekly.md" "" "work" ""
    open_file "$file"
    ;;

  pw|personal-week)
    file="$(personal_week_path)"
    ensure_file "$file" "$VAULT/templates/personal-weekly.md" "" "personal" ""
    open_file "$file"
    ;;

  pd|personal-day)
    file="$(personal_day_path)"
    ensure_file "$file" "$VAULT/templates/personal-daily.md" "" "personal" ""
    open_file "$file"
    ;;

  project)
    scope="${2:-}"

    if [ -z "$scope" ]; then
      echo "Missing scope."
      echo "Example: note project jotform \"Custom Domain Management\""
      exit 1
    fi

    shift 2
    title="$*"

    if [ -z "$title" ]; then
      echo "Missing title."
      echo "Example: note project jotform \"Custom Domain Management\""
      exit 1
    fi

    slug="$(slugify "$title")"
    file="$VAULT/projects/$scope/$slug.md"

    ensure_file "$file" "$VAULT/templates/project.md" "$title" "$scope" ""
    open_file "$file"
    ;;

  zk)
    area="${2:-}"

    if [ -z "$area" ]; then
      echo "Missing area."
      echo "Example: note zk development \"Domain Routing Patterns\""
      exit 1
    fi

    shift 2
    title="$*"

    if [ -z "$title" ]; then
      echo "Missing title."
      echo "Example: note zk development \"Domain Routing Patterns\""
      exit 1
    fi

    slug="$(slugify "$title")"
    file="$VAULT/zk/$area/$slug.md"

    ensure_file "$file" "$VAULT/templates/zk.md" "$title" "" "$area"
    open_file "$file"
    ;;

    ensure-path)
  kind="${2:-}"

  case "$kind" in
    jw)
      file="$(jotform_week_path)"
      ensure_file "$file" "$VAULT/templates/jotform-weekly.md" "" "work" ""
      echo "$file"
      ;;

    pw)
      file="$(personal_week_path)"
      ensure_file "$file" "$VAULT/templates/personal-weekly.md" "" "personal" ""
      echo "$file"
      ;;

    pd)
      file="$(personal_day_path)"
      ensure_file "$file" "$VAULT/templates/personal-daily.md" "" "personal" ""
      echo "$file"
      ;;

    project)
      scope="${3:-}"
      shift 3
      title="$*"

      if [ -z "$scope" ] || [ -z "$title" ]; then
        echo "Usage: note ensure-path project jotform \"Custom Domain Management\""
        exit 1
      fi

      slug="$(slugify "$title")"
      file="$VAULT/projects/$scope/$slug.md"

      ensure_file "$file" "$VAULT/templates/project.md" "$title" "$scope" ""
      echo "$file"
      ;;

    zk)
      area="${3:-}"
      shift 3
      title="$*"

      if [ -z "$area" ] || [ -z "$title" ]; then
        echo "Usage: note ensure-path zk development \"Domain Routing Patterns\""
        exit 1
      fi

      slug="$(slugify "$title")"
      file="$VAULT/zk/$area/$slug.md"

      ensure_file "$file" "$VAULT/templates/zk.md" "$title" "" "$area"
      echo "$file"
      ;;

    *)
      echo "Unknown ensure-path kind: $kind"
      echo "Use: jw, pw, pd, project, zk"
      exit 1
      ;;
  esac
  ;;

  path)
    kind="${2:-}"

    case "$kind" in
      jw)
        echo "$(jotform_week_path)"
        ;;

      pw)
        echo "$(personal_week_path)"
        ;;

      pd)
        echo "$(personal_day_path)"
        ;;

      *)
        echo "Unknown path kind: $kind"
        echo "Use: jw, pw, pd"
        exit 1
        ;;
    esac
    ;;

  *)
    echo "Usage:"
    echo "  note jw"
    echo "  note pw"
    echo "  note pd"
    echo "  note project jotform \"Custom Domain Management\""
    echo "  note project personal/ganyan-ai \"Experiment 001\""
    echo "  note zk development \"Domain Routing Patterns\""
    echo "  note zk ai-ml \"Feature Leakage\""
    echo ""
    echo "Nvim helper:"
    echo "  note ensure-path jw"
    echo "  note ensure-path pw"
    echo "  note ensure-path pd"
    exit 1
    ;;
esac
