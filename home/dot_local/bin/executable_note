#!/usr/bin/env bash

set -euo pipefail

VAULT="${NOTES_VAULT:-$HOME/notes}"
EDITOR_CMD="${EDITOR:-nvim}"

slugify() {
  echo "$*" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-|-$//g'
}

week_path() {
  local offset
  offset=$(( $(date +%u) - 1 ))
  if [[ "$(uname)" == "Darwin" ]]; then
    echo "$VAULT/journal/$(date -v-${offset}d +%F).md"
  else
    echo "$VAULT/journal/$(date -d "$offset days ago" +%F).md"
  fi
}

ensure_file() {
  local file="$1"
  local template="$2"

  mkdir -p "$(dirname "$file")"
  if [ ! -f "$file" ]; then
    sed -e "s|{{date}}|$(date +%F)|g" "$template" > "$file"
  fi
}

case "${1:-}" in
  week)
    file="$(week_path)"
    ensure_file "$file" "$VAULT/templates/weekly.md"
    "$EDITOR_CMD" "$file"
    ;;

  zk)
    shift 1
    title="$*"
    if [ -z "$title" ]; then
      echo "Missing title."
      echo "Example: note zk \"Domain Routing Patterns\""
      exit 1
    fi

    slug="$(slugify "$title")"
    file="$VAULT/zk/$slug.md"
    ensure_file "$file" "$VAULT/templates/zk.md"
    "$EDITOR_CMD" "$file"
    ;;

  ensure-path)
    case "${2:-}" in
      week)
        file="$(week_path)"
        ensure_file "$file" "$VAULT/templates/weekly.md"
        echo "$file"
        ;;
      zk)
        shift 2
        title="$*"
        slug="$(slugify "$title")"
        file="$VAULT/zk/$slug.md"
        ensure_file "$file" "$VAULT/templates/zk.md"
        echo "$file"
        ;;
      *)
        echo "Use: week, zk"
        exit 1
        ;;
    esac
    ;;

  *)
    echo "Usage:"
    echo "  note week"
    echo "  note zk \"Domain Routing Patterns\""
    exit 1
    ;;
esac
