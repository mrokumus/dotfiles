# Tmux plugins — managed by tpm, cloned as git repos
[".config/tmux/plugins/tpm"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tpm.git"
    refreshPeriod = "168h"

[".config/tmux/plugins/tmux-resurrect"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tmux-resurrect.git"
    refreshPeriod = "168h"

[".config/tmux/plugins/tmux-continuum"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tmux-continuum.git"
    refreshPeriod = "168h"

[".config/tmux/plugins/vim-tmux-navigator"]
    type = "git-repo"
    url = "https://github.com/christoomey/vim-tmux-navigator.git"
    refreshPeriod = "168h"

# Jotform private configs — only on jotform hostname.
# Uses the SSH host alias `mrokumus` so work machines can pick the correct key
# from ~/.ssh/config instead of falling back to the default github.com identity.
{{- if eq .chezmoi.hostname "jotform" }}
[".config/jotform-private"]
    type = "git-repo"
    url = "mrokumus:mrokumus/dotfiles-jotform.git"
    refreshPeriod = "168h"
{{- end }}

# Personal private configs — all non-Jotform personal machines.
# Keep local LLM tooling, private scripts, and personal-only packages here.
{{- if ne .chezmoi.hostname "jotform" }}
[".config/personal-private"]
    type = "git-repo"
    url = "git@github.com:mrokumus/dotfiles-personal.git"
    refreshPeriod = "168h"
{{- end }}
