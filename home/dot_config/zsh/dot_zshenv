# Path
export ZDOTDIR="$HOME/.config/zsh"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"
export SCRIPTS_DIR="$HOME/.config/scripts"
export PATH="$SCRIPTS_DIR:$SCRIPTS_DIR/bin:/opt/homebrew/bin:(go env GOPATH)/bin:$PATH"
export GOPATH=$HOME/go
export STARSHIP_CONFIG=~/.config/starship/starship.toml
export GIT_CONFIG_GLOBAL="$HOME/.config/git/.gitconfig"

# Locale
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"
export LC_CTYPE="en_US.UTF-8"

# Editor
export EDITOR="nvim"
export VISUAL="nvim"

export NVM_DIR="$HOME/.nvm"
  [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"  # This loads nvm
  [ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion

# pnpm
export PNPM_HOME=$HOME"/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

export PATH="/opt/homebrew/opt/openjdk/bin:$PATH"
export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
export PATH="/opt/homebrew/bin/composer:$PATH"
export PATH="$PATH:$HOME/.config/composer/vendor/bin"
export PATH="$HOME/.local/bin:$PATH"
export PATH="/opt/homebrew/bin:$PATH"

if [ -f "$HOME/.config/zsh/functions.zsh" ]; then
    export PATH="$PATH:$HOME/go/bin"
fi

# Settings
export HISTORY_IGNORE="(ls|cd|pwd|exit|history|cd - | cd ..)"
. "$HOME/.cargo/env"
